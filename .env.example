# LLM Provider — choose one: bedrock | anthropic | ollama
LLM_PROVIDER=bedrock

# Amazon Bedrock
AWS_REGION=us-east-1
AWS_PROFILE=default

# Anthropic direct (alternative to Bedrock)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local, no account required)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Vault
VAULT_PATH=/path/to/your/obsidian/vault

# Context budget (max tokens allocated to vault context per request)
CONTEXT_BUDGET_TOKENS=8000

# LLM Provider — choose one: bedrock | anthropic | ollama
LLM_PROVIDER=bedrock

# Amazon Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# Anthropic direct (alternative to Bedrock)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local, no account required)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Vault
VAULT_ROOT=/path/to/your/obsidian/vault

# Context budget (max tokens allocated to vault context per request)
CONTEXT_BUDGET_TOKENS=8000

# Logging
# LOG_LEVEL=info          # trace | debug | info | warn | error | silent (default: info)
# LOG_FILE=lorecraft.log  # path to JSON log file (default: lorecraft.log in cwd)
